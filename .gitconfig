# ─────────────────────────────────────────
# Core Settings
# ─────────────────────────────────────────
[core]
	# normalise line endings to LF on commit
	autocrlf = input

[init]
	defaultBranch = main

[pull]
	rebase = false

[push]
	autoSetupRemote = true

# ─────────────────────────────────────────
# Aliases
# ─────────────────────────────────────────
[alias]
	# -- History
	hist = log --all --graph --decorate --date=short --pretty=format:"%C(yellow)%h%Creset %C(cyan)%ad%Creset%C(red)%d%Creset %s%C(dim blue) [%an]%Creset"
	lo   = log --oneline
	l    = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short
	ld   = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative

	# -- Workflow
	co  = checkout
	c   = commit
	cm  = commit -m
	cam = commit -am
	st  = status
	pl  = pull
	ps  = push
	br  = branch
	ta  = tag --list

# ─────────────────────────────────────────
# GPG
# ─────────────────────────────────────────
[gpg]
	program = gpg

# ─────────────────────────────────────────
# Git LFS
# ─────────────────────────────────────────
# pre-set so the idempotency check in setup_git_lfs always finds these values here
[filter "lfs"]
	smudge  = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean   = git-lfs clean -- %f

# ─────────────────────────────────────────
# Local Identity (machine-specific, not tracked)
# ─────────────────────────────────────────
# user.name, user.email, user.signingkey, and core.editor live in ~/.gitconfig.local
# which is created by install.sh and never committed to the repo
[include]
	path = ~/.gitconfig.local
