# Repo-wide shellcheck config - see README's Contributing section for how this is run.
# Note: run shellcheck with --severity=warning (not settable from this rcfile) to skip
# "info"/"style" nitpicks - e.g. SC2059 for printf "${COLOR}..." format strings, which
# is this repo's deliberate, safe, repo-wide convention for ANSI color output (the vars
# are static escape codes defined once in scripts/helpers.sh, never derived from user input).

# scripts/*.sh are never executed directly, only sourced by install.sh/run.sh/doctor.sh -
# they intentionally have no shebang
disable=SC2148

# "~/path" strings throughout this repo are literal text handed to output helpers for
# human-readable display (e.g. `_pass "~/.zshrc ..."`), not paths meant to expand
disable=SC2088
