# ─────────────────────────────────────────
# User Identity
# ─────────────────────────────────────────
[user]
	name = DevTruce
	email = 85980370+DevTruce@users.noreply.github.com
	# replace with your GPG key ID after running install.sh
	signingkey = gpg_sec_key

# ─────────────────────────────────────────
# Core Settings
# ─────────────────────────────────────────
[core]
	editor = code --wait
	# normalise line endings to LF on commit
	autocrlf = input

# ─────────────────────────────────────────
# Commit & Tag Signing
# ─────────────────────────────────────────
[commit]
	gpgsign = true
[tag]
	gpgsign = true

# ─────────────────────────────────────────
# Aliases
# ─────────────────────────────────────────
[alias]
	# -- History
	hist = log --all --graph --decorate --oneline --pretty
	lo   = log --oneline
	l    = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short
	lds  = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short
	ld   = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative

	# -- Workflow
	co  = checkout
	c   = commit
	cm  = commit -m
	cam = commit -am
	st  = status
	pl  = pull
	ps  = push
	br  = branch
	ta  = tag --list

# ─────────────────────────────────────────
# Git LFS
# ─────────────────────────────────────────
# auto-populated by `git lfs install` — do not edit manually
[filter "lfs"]
	smudge  = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean   = git-lfs clean -- %f
