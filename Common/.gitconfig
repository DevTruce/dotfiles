# ---------------------
# User Identity
# ---------------------
[user]
	name = DevTruce
	email = 85980370+DevTruce@users.noreply.github.com
	signingkey = gpg_sec_key

# ---------------------
# Core Git Settings
# ---------------------
[core]
	editor = code --wait
	autocrlf = input 

# ---------------------
# Commit/Tag Signing
# ---------------------
[commit]
	gpgsign = true
[tag]
	gpgsign = true

# ---------------------
# Custom Git Aliases
# ---------------------
[alias]  
	hist = log --all --graph --decorate --oneline --pretty # clean git history log
	lo = log --oneline # display git history in one line 
	l = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short # List commits in short form, with colors and branch/tag annotations
  lds = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=short # List oneline commits showing dates
	ld = log --pretty=format:"%C(yellow)%h\\ %ad%Cred%d\\ %Creset%s%Cblue\\ [%cn]" --decorate --date=relative # List oneline commits showing relative dates:
	co = checkout # switch branches 
	c = commit # make commits 
	cm = commit -m # make commits with a message
	cam = commit -am # add and commit with a message 
	st = status # display git commit status
  pl = pull # pull commits
	ps = push # push commits 
	br = branch # Display all branches & * the current working branch
	ta = tag --list # Display tag list 

# ---------------------
# Git LFS Config
# ---------------------
# this auto populates once you setup git lfs
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
